{
  "name": "@galdor/provider-google",
  "version": "0.1.0",
  "type": "module",
  "description": "Google (Gemini / Generative Language API) provider adapter for galdor-bun.",
  "author": {
    "name": "Yasser Rosas",
    "email": "yassros16@gmail.com"
  },
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=22.5",
    "bun": ">=1.3"
  },
  "dependencies": {
    "@galdor/core": "workspace:*"
  }
}
