{
  "name": "@galdor/core",
  "version": "0.1.0",
  "type": "module",
  "description": "galdor-bun core: schema, provider, tool, graph, agent, observability.",
  "author": {
    "name": "Yasser Rosas",
    "email": "yassros16@gmail.com"
  },
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "bun": "./src/schema/index.ts",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./provider": {
      "bun": "./src/provider/index.ts",
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    },
    "./tool": {
      "bun": "./src/tool/index.ts",
      "types": "./dist/tool/index.d.ts",
      "import": "./dist/tool/index.js"
    },
    "./testprovider": {
      "bun": "./src/testprovider/index.ts",
      "types": "./dist/testprovider/index.d.ts",
      "import": "./dist/testprovider/index.js"
    },
    "./graph": {
      "bun": "./src/graph/index.ts",
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./agent": {
      "bun": "./src/agent/index.ts",
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./store": {
      "bun": "./src/store/index.ts",
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js"
    },
    "./observability": {
      "bun": "./src/observability/index.ts",
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js"
    },
    "./eval": {
      "bun": "./src/eval/index.ts",
      "types": "./dist/eval/index.d.ts",
      "import": "./dist/eval/index.js"
    },
    "./replay": {
      "bun": "./src/replay/index.ts",
      "types": "./dist/replay/index.d.ts",
      "import": "./dist/replay/index.js"
    },
    "./memory": {
      "bun": "./src/memory/index.ts",
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./embedder": {
      "bun": "./src/embedder/index.ts",
      "types": "./dist/embedder/index.d.ts",
      "import": "./dist/embedder/index.js"
    },
    "./spellbook": {
      "bun": "./src/spellbook/index.ts",
      "types": "./dist/spellbook/index.d.ts",
      "import": "./dist/spellbook/index.js"
    },
    "./council": {
      "bun": "./src/council/index.ts",
      "types": "./dist/council/index.d.ts",
      "import": "./dist/council/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=22.5",
    "bun": ">=1.3"
  },
  "dependencies": {
    "zod": "^4.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0"
  }
}
